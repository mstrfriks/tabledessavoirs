{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tabledessavoirs",
  "main": "_worker.js",
  "compatibility_date": "2026-05-15",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "kv_namespaces": [
    { "binding": "TDS_KV", "id": "a9f59a16db264a5f8ecd8965ce23b451" }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
